generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  subdomain         String             @unique
  level             Level
  boardingType      BoardingType
  subStatus         SubStatus          @default(ACTIVE)
  subTier           SubTier            @default(STARTER)
  featureFlags      Json               @default("{}")
  branding          Json               @default("{}")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  academicSessions  AcademicSession[]
  assignments       Assignment[]
  attendance        Attendance[]
  beds              Bed[]
  caWeights         CaWeight[]
  classes           Class[]
  classNotes        ClassNote[]
  dormitories       Dormitory[]
  feeCategories     FeeCategory[]
  gradingScales     GradingScale[]
  hostelAllocations HostelAllocation[]
  invoiceItems      InvoiceItem[]
  invoices          Invoice[]
  notices           Notice[]
  payments          Payment[]
  roles             Role[]
  scores            Score[]
  sportsEvents      SportsEvent[]
  sportsHouses      SportsHouse[]
  students          Student[]
  subjects          Subject[]
  submissions       Submission[]
  users             User[]

  @@map("tenants")
}

model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String? @db.Uuid
  name        String
  permissions Json    @default("[]")
  tenant      Tenant? @relation(fields: [tenantId], references: [id])
  users       User[]

  @@unique([tenantId, name])
  @@map("roles")
}

model User {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String?  @db.Uuid
  email           String   @unique
  passwordHash    String
  roleId          String   @db.Uuid
  profile         Json     @default("{}")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  submittedScores    Score[]      @relation("ScoreSubmitter")
  markedAttendances  Attendance[] @relation("AttendanceMarker")
  authoredNotices    Notice[]     @relation("NoticeAuthor")
  student            Student?
  role               Role         @relation(fields: [roleId], references: [id])
  tenant             Tenant?      @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model AcademicSession {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String             @db.Uuid
  name              String
  startDate         DateTime?          @db.Date
  endDate           DateTime?          @db.Date
  isCurrent         Boolean            @default(false)
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  attendance        Attendance[]
  classes           Class[]
  classNotes        ClassNote[]
  assignments       Assignment[]
  hostelAllocations HostelAllocation[]
  invoices          Invoice[]
  scores            Score[]

  @@map("academic_sessions")
}

model GradingScale {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String    @db.Uuid
  name     String
  bands    Json
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  subjects Subject[]

  @@map("grading_scales")
}

model Subject {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String        @db.Uuid
  name           String
  code           String?
  department     String?
  gradingScaleId String?       @db.Uuid
  caWeights      CaWeight[]
  scores         Score[]
  classNotes     ClassNote[]
  assignments    Assignment[]
  gradingScale   GradingScale? @relation(fields: [gradingScaleId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id])

  @@map("subjects")
}

model Class {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String          @db.Uuid
  name      String
  level     String?
  arm       String?
  sessionId String          @db.Uuid
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  students    Student[]
  attendance  Attendance[]
  classNotes  ClassNote[]
  assignments Assignment[]

  @@map("classes")
}

model Student {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String             @db.Uuid
  userId            String?            @unique @db.Uuid
  admissionNo       String
  classId           String?            @db.Uuid
  boardingStatus    BoardingStatus     @default(DAY)
  sportsHouseId     String?            @db.Uuid
  createdAt         DateTime           @default(now())
  attendance        Attendance[]
  hostelAllocations HostelAllocation[]
  invoices          Invoice[]
  scores            Score[]
  submissions       Submission[]
  class             Class?             @relation(fields: [classId], references: [id])
  sportsHouse       SportsHouse?       @relation(fields: [sportsHouseId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  user              User?              @relation(fields: [userId], references: [id])

  @@unique([tenantId, admissionNo])
  @@map("students")
}

model CaWeight {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String  @db.Uuid
  subjectId  String  @db.Uuid
  components Json
  subject    Subject @relation(fields: [subjectId], references: [id])
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  @@map("ca_weights")
}

model Score {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String          @db.Uuid
  studentId   String          @db.Uuid
  subjectId   String          @db.Uuid
  sessionId   String          @db.Uuid
  term        Term
  components  Json
  total       Decimal         @db.Decimal(5, 2)
  submittedBy String?         @db.Uuid
  submittedAt DateTime        @default(now())
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  student     Student         @relation(fields: [studentId], references: [id])
  subject     Subject         @relation(fields: [subjectId], references: [id])
  submitter   User?           @relation("ScoreSubmitter", fields: [submittedBy], references: [id])
  tenant      Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, studentId, subjectId, sessionId, term])
  @@map("scores")
}

model Dormitory {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @db.Uuid
  name     String
  gender   Gender
  capacity Int
  beds     Bed[]
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@map("dormitories")
}

model Bed {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String             @db.Uuid
  dormitoryId String             @db.Uuid
  roomNumber  String
  bedNumber   String
  status      BedStatus          @default(VACANT)
  dormitory   Dormitory          @relation(fields: [dormitoryId], references: [id])
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  allocations HostelAllocation[]

  @@unique([tenantId, dormitoryId, roomNumber, bedNumber])
  @@map("beds")
}

model HostelAllocation {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String          @db.Uuid
  bedId       String          @db.Uuid
  studentId   String          @db.Uuid
  sessionId   String          @db.Uuid
  allocatedAt DateTime        @default(now())
  bed         Bed             @relation(fields: [bedId], references: [id])
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  student     Student         @relation(fields: [studentId], references: [id])
  tenant      Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, studentId, sessionId])
  @@map("hostel_allocations")
}

model SportsHouse {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  colour    String?
  captainId String?   @db.Uuid
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  students  Student[]

  @@map("sports_houses")
}

model SportsEvent {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  eventDate DateTime? @db.Date
  category  String?
  results   Json      @default("[]")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("sports_events")
}

model Attendance {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String           @db.Uuid
  classId   String           @db.Uuid
  sessionId String           @db.Uuid
  date      DateTime         @db.Date
  studentId String           @db.Uuid
  status    AttendanceStatus @default(PRESENT)
  markedBy  String?          @db.Uuid
  notes     String?
  createdAt DateTime         @default(now())
  class     Class            @relation(fields: [classId], references: [id])
  session   AcademicSession  @relation(fields: [sessionId], references: [id])
  student   Student          @relation(fields: [studentId], references: [id])
  marker    User?            @relation("AttendanceMarker", fields: [markedBy], references: [id])
  tenant    Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, classId, date, studentId])
  @@map("attendance")
}

model Notice {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String         @db.Uuid
  title       String
  body        String
  category    NoticeCategory @default(GENERAL)
  isPinned    Boolean        @default(false)
  targetRoles Json           @default("[]")
  publishedAt DateTime       @default(now())
  expiresAt   DateTime?
  authorId    String?        @db.Uuid
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  author      User?          @relation("NoticeAuthor", fields: [authorId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  @@map("notices")
}

model FeeCategory {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String        @db.Uuid
  name          String
  description   String?
  defaultAmount Decimal?      @db.Decimal(10, 2)
  isActive      Boolean       @default(true)
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  items         InvoiceItem[]

  @@map("fee_categories")
}

model Invoice {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String          @db.Uuid
  studentId   String          @db.Uuid
  sessionId   String          @db.Uuid
  term        Term
  status      InvoiceStatus   @default(UNPAID)
  totalAmount Decimal         @db.Decimal(10, 2)
  dueDate     DateTime?       @db.Date
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  items       InvoiceItem[]
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  student     Student         @relation(fields: [studentId], references: [id])
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  payments    Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String      @db.Uuid
  invoiceId     String      @db.Uuid
  feeCategoryId String      @db.Uuid
  description   String?
  amount        Decimal     @db.Decimal(10, 2)
  feeCategory   FeeCategory @relation(fields: [feeCategoryId], references: [id])
  invoice       Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @db.Uuid
  invoiceId     String         @db.Uuid
  amount        Decimal        @db.Decimal(10, 2)
  currency      String         @default("USD")
  gateway       PaymentGateway
  gatewayRef    String?
  gatewayStatus String?
  status        PaymentStatus  @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime       @default(now())
  invoice       Invoice        @relation(fields: [invoiceId], references: [id])
  tenant        Tenant         @relation(fields: [tenantId], references: [id])

  @@map("payments")
}

model ClassNote {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String          @db.Uuid
  classId   String          @db.Uuid
  subjectId String?         @db.Uuid
  sessionId String          @db.Uuid
  term      Term
  title     String
  body      String
  authorId  String          @db.Uuid
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  class     Class           @relation(fields: [classId], references: [id])
  subject   Subject?        @relation(fields: [subjectId], references: [id])
  session   AcademicSession @relation(fields: [sessionId], references: [id])

  @@map("class_notes")
}

model Assignment {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String          @db.Uuid
  classId      String          @db.Uuid
  subjectId    String?         @db.Uuid
  sessionId    String          @db.Uuid
  term         Term
  type         AssignmentType  @default(HOMEWORK)
  title        String
  instructions String
  dueDate      DateTime?
  maxScore     Int             @default(100)
  authorId     String          @db.Uuid
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  class        Class           @relation(fields: [classId], references: [id])
  subject      Subject?        @relation(fields: [subjectId], references: [id])
  session      AcademicSession @relation(fields: [sessionId], references: [id])
  submissions  Submission[]

  @@map("assignments")
}

model Submission {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String     @db.Uuid
  assignmentId String     @db.Uuid
  studentId    String     @db.Uuid
  content      String
  submittedAt  DateTime   @default(now())
  score        Int?
  feedback     String?
  gradedBy     String?    @db.Uuid
  gradedAt     DateTime?
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("submissions")
}

enum Level {
  PRIMARY
  SECONDARY
  K_12
}

enum BoardingType {
  DAY_ONLY
  BOARDING_ONLY
  HYBRID
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  SUSPENDED
}

enum SubTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum BoardingStatus {
  DAY
  BOARDER
}

enum Term {
  FIRST
  SECOND
  THIRD
}

enum Gender {
  MALE
  FEMALE
  MIXED
}

enum BedStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentGateway {
  PAYPAL
  STRIPE
  BANK_TRANSFER
  CASH
}

enum AssignmentType {
  HOMEWORK
  CLASSWORK
  ASSIGNMENT
  PROJECT
  TEST
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum NoticeCategory {
  GENERAL
  ACADEMIC
  FINANCE
  HOSTEL
  SPORTS
  EMERGENCY
}
