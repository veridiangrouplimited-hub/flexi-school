generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANTS ─────────────────────────────────────────────────────────────────

model Tenant {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  subdomain    String      @unique
  level        Level
  boardingType BoardingType
  subStatus    SubStatus   @default(ACTIVE)
  subTier      SubTier     @default(STARTER)
  featureFlags Json        @default("{}")
  branding     Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  roles             Role[]
  users             User[]
  academicSessions  AcademicSession[]
  gradingScales     GradingScale[]
  subjects          Subject[]
  classes           Class[]
  students          Student[]
  caWeights         CaWeight[]
  scores            Score[]
  dormitories       Dormitory[]
  beds              Bed[]
  hostelAllocations HostelAllocation[]
  sportsHouses      SportsHouse[]
  sportsEvents      SportsEvent[]

  @@map("tenants")
}

enum Level {
  PRIMARY
  SECONDARY
  K_12
}

enum BoardingType {
  DAY_ONLY
  BOARDING_ONLY
  HYBRID
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  SUSPENDED
}

enum SubTier {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Role {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String? @db.Uuid
  name        String
  permissions Json    @default("[]")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  users  User[]

  @@unique([tenantId, name])
  @@map("roles")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String?  @db.Uuid
  email        String   @unique
  passwordHash String
  roleId       String   @db.Uuid
  profile      Json     @default("{}")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  tenant          Tenant?  @relation(fields: [tenantId], references: [id])
  role            Role     @relation(fields: [roleId], references: [id])
  student         Student?
  submittedScores Score[]  @relation("ScoreSubmitter")

  @@map("users")
}

// ─── ACADEMIC CORE ───────────────────────────────────────────────────────────

model AcademicSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  startDate DateTime? @db.Date
  endDate   DateTime? @db.Date
  isCurrent Boolean   @default(false)

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  classes           Class[]
  scores            Score[]
  hostelAllocations HostelAllocation[]

  @@map("academic_sessions")
}

model GradingScale {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @db.Uuid
  name     String
  bands    Json

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  subjects Subject[]

  @@map("grading_scales")
}

model Subject {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String  @db.Uuid
  name           String
  code           String?
  department     String?
  gradingScaleId String? @db.Uuid

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  gradingScale GradingScale? @relation(fields: [gradingScaleId], references: [id])
  caWeights    CaWeight[]
  scores       Score[]

  @@map("subjects")
}

model Class {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @db.Uuid
  name      String
  level     String?
  arm       String?
  sessionId String  @db.Uuid

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  session  AcademicSession @relation(fields: [sessionId], references: [id])
  students Student[]

  @@map("classes")
}

model Student {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String        @db.Uuid
  userId         String?       @unique @db.Uuid
  admissionNo    String
  classId        String?       @db.Uuid
  boardingStatus BoardingStatus @default(DAY)
  sportsHouseId  String?       @db.Uuid
  createdAt      DateTime      @default(now())

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  user              User?              @relation(fields: [userId], references: [id])
  class             Class?             @relation(fields: [classId], references: [id])
  sportsHouse       SportsHouse?       @relation(fields: [sportsHouseId], references: [id])
  scores            Score[]
  hostelAllocations HostelAllocation[]

  @@unique([tenantId, admissionNo])
  @@map("students")
}

enum BoardingStatus {
  DAY
  BOARDER
}

model CaWeight {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String @db.Uuid
  subjectId  String @db.Uuid
  components Json

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@map("ca_weights")
}

model Score {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  studentId   String   @db.Uuid
  subjectId   String   @db.Uuid
  sessionId   String   @db.Uuid
  term        Term
  components  Json
  total       Decimal  @db.Decimal(5, 2)
  submittedBy String?  @db.Uuid
  submittedAt DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  student   Student         @relation(fields: [studentId], references: [id])
  subject   Subject         @relation(fields: [subjectId], references: [id])
  session   AcademicSession @relation(fields: [sessionId], references: [id])
  submitter User?           @relation("ScoreSubmitter", fields: [submittedBy], references: [id])

  @@unique([tenantId, studentId, subjectId, sessionId, term])
  @@map("scores")
}

enum Term {
  FIRST
  SECOND
  THIRD
}

// ─── HOSTEL / BOARDING ───────────────────────────────────────────────────────

model Dormitory {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @db.Uuid
  name     String
  gender   Gender
  capacity Int

  tenant Tenant @relation(fields: [tenantId], references: [id])
  beds   Bed[]

  @@map("dormitories")
}

enum Gender {
  MALE
  FEMALE
  MIXED
}

model Bed {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  dormitoryId String    @db.Uuid
  roomNumber  String
  bedNumber   String
  status      BedStatus @default(VACANT)

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  dormitory   Dormitory          @relation(fields: [dormitoryId], references: [id])
  allocations HostelAllocation[]

  @@unique([tenantId, dormitoryId, roomNumber, bedNumber])
  @@map("beds")
}

enum BedStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

model HostelAllocation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  bedId       String   @db.Uuid
  studentId   String   @db.Uuid
  sessionId   String   @db.Uuid
  allocatedAt DateTime @default(now())

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  bed     Bed             @relation(fields: [bedId], references: [id])
  student Student         @relation(fields: [studentId], references: [id])
  session AcademicSession @relation(fields: [sessionId], references: [id])

  @@unique([tenantId, studentId, sessionId])
  @@map("hostel_allocations")
}

// ─── SPORTS ──────────────────────────────────────────────────────────────────

model SportsHouse {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @db.Uuid
  name      String
  colour    String?
  captainId String? @db.Uuid

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  students Student[]

  @@map("sports_houses")
}

model SportsEvent {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  name      String
  eventDate DateTime? @db.Date
  category  String?
  results   Json      @default("[]")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("sports_events")
}
