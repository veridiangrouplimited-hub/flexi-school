# Copy this file to .env and fill in real values — never commit .env

# Neon (or any Postgres) connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET="change-me"

# Server port
PORT=4000

# PayPal sandbox credentials
# Get from https://developer.paypal.com → My Apps & Credentials → Sandbox
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# "sandbox" for testing, "live" for production
PAYPAL_ENV="sandbox"

# The URL where the frontend is running (used for PayPal return/cancel URLs)
FRONTEND_URL="http://localhost:5173"

# Currency for all invoices (ISO 4217 code)
FINANCE_CURRENCY="USD"
